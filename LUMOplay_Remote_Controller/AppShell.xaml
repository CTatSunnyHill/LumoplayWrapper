<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LUMOplay_Remote_Controller.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:LUMOplay_Remote_Controller"
    xmlns:views="clr-namespace:LUMOplay_Remote_Controller.Views"
    Title="LUMOplay_Remote_Controller"
    FlyoutBehavior="Locked"
    Shell.BackgroundColor="#F0F2F5"
    Shell.NavBarIsVisible="False">

    <FlyoutItem Title="Dashboard" Icon="library.png">
        <ShellContent
            Title="Dashboard"
            ContentTemplate="{DataTemplate views:DashboardPage}"
            Route="DashboardPage" />
    </FlyoutItem>

    <FlyoutItem Title="Playlists" Icon="library.png">
        <ShellContent
            Title="PLaylists"
            ContentTemplate="{DataTemplate views:PlaylistPage}"
            Route="PlaylistPage" />
    </FlyoutItem>

    <FlyoutItem Title="Game Library" Icon="library.png">
        <ShellContent
            Title="Game Library"
            ContentTemplate="{DataTemplate views:GameLibraryPage}"
            Route="GameLibraryPage" />
    </FlyoutItem>

</Shell>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LUMOplay_Remote_Controller.Views.SelectDevicePopup"
             Title="Select Device"
             BackgroundColor="#80000000"
             Padding="32">
    <Frame BackgroundColor="White" Padding="24" CornerRadius="16" HasShadow="True" VerticalOptions="Center" HorizontalOptions="Center">
        <VerticalStackLayout Spacing="18">
            <Label Text="Select Device" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />
            <Picker ItemsSource="{Binding Devices}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                    Title="Choose device"
                    WidthRequest="250" />
            <Button Text="Play"
                    Command="{Binding PlayCommand}"
                    IsEnabled="{Binding SelectedDevice, Converter={StaticResource NullToBoolConverter}}"
                    BackgroundColor="#5B4EFF"
                    TextColor="White"
                    CornerRadius="8"
                    FontSize="18" />
        </VerticalStackLayout>
    </Frame>
</ContentPage>